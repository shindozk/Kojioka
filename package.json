{
  "name": "kojioka",
  "version": "2.7.1",
  "description": "Official client for the Kojioka Music Streaming API",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:clean && npm run build:cjs && npm run build:esm && npm run build:types",
    "build:clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:types": "tsc -p tsconfig.types.json",
    "test": "jest --forceExit",
    "lint": "tsc -p tsconfig.types.json --noEmit"
  },
  "keywords": [
    "kojioka",
    "music",
    "streaming",
    "api",
    "client",
    "youtube",
    "soundcloud",
    "lastfm"
  ],
  "author": "shindozk",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
